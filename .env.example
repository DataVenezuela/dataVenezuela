# Copia este archivo a .env.local y ajusta los valores.
#   cp .env.example .env.local
#
# Los valores de abajo son los DEFAULTS de Supabase local (los imprime
# `npx supabase start`). Son llaves de demo públicas: NO las uses en producción.

# --- Supabase ---
# URL de la API. Local usa el puerto personalizado 54421 (ver supabase/config.toml).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54421

# Llave anónima (cliente del navegador; respeta RLS).
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# Llave service-role (SOLO servidor; bypassa RLS). Nunca exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# --- App ---
# Sal para hashear las API keys de escritura: sha256(key + sal).
# CÁMBIALA en producción; si cambia, las keys existentes dejan de validar.
PARTNER_API_SALT=dev-local-salt-change-me

# URL del servidor para el script de pruebas `npm run e2e` (opcional).
# APP_URL=http://localhost:3000
